{
  "name": "@cubist-labs/cubesigner-workspace",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cubist-labs/CubeSigner-TypeScript-SDK.git"
  },
  "version": "0.4.265",
  "private": true,
  "description": "",
  "homepage": "https://github.com/cubist-labs/CubeSigner-TypeScript-SDK",
  "bugs": "https://github.com/cubist-labs/CubeSigner-TypeScript-SDK/issues",
  "license": "(MIT-0 OR Apache-2.0)",
  "author": "Cubist, Inc.",
  "workspaces": [
    "packages/sdk",
    "packages/browser-storage",
    "packages/fs-storage",
    "packages/org-utils",
    "packages/secretsmanager-storage",
    "packages/ethers-v6",
    "packages/key-import",
    "packages/viem"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:examples": "for e in examples/*; do npm -C $e ci --ignore-scripts && npm -C $e run build || exit 1; done",
    "test": "npm run test --workspaces --if-present -- --passWithNoTests",
    "test:playwright": "npm run test:playwright --workspaces --if-present -- --pass-with-no-tests",
    "check:licenses": "license-checker-rseidelsohn --excludePrivatePackages --summary --onlyAllow '0BSD;Apache-2.0;BSD-2-Clause;BSD-3-Clause;BlueOak-1.0.0;CC-BY-3.0;CC-BY-4.0;CC0-1.0;ISC;MIT;Python-2.0;MPL-2.0'",
    "fix": "eslint . --fix",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "fmt-check": "prettier --check ."
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.16.0",
    "@types/chai": "^4.3.11",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^22.5.2",
    "@types/node-fetch": "^2.6.11",
    "@types/tmp": "^0.2.6",
    "chai": "^4.4.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.16.0",
    "eslint-config-google": "git://github.com/google/eslint-config-google#3ae571a",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-chai-friendly": "^1.0.1",
    "eslint-plugin-jsdoc": "^50.2.2",
    "globals": "^15.13.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "openapi-typescript": "^6.7.5",
    "otplib": "^12.0.1",
    "prettier": "3.3.3",
    "tmp": "^0.2.3",
    "ts-node": "^10.9.2",
    "typedoc": "^0.27.9",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.17.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "idb": "^8.0.0"
  }
}
